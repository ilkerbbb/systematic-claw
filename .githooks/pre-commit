#!/usr/bin/env bash
# systematic-claw pre-commit hook
# Checks STAGED .ts files for TypeScript syntax errors
set -e

errors=0

# Get staged TS files
staged_ts=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' 2>/dev/null || true)

if [ -n "$staged_ts" ]; then
  echo "Checking staged TypeScript files..."
  if ! npx tsc --noEmit --esModuleInterop --skipLibCheck --target es2020 --moduleResolution node16 --module node16 index.ts src/**/*.ts 2>/dev/null; then
    echo "TypeScript check failed."
    errors=$((errors + 1))
  fi
fi

if [ "$errors" -gt 0 ]; then
  echo ""
  echo "BLOCKED: Fix TypeScript errors before committing."
  exit 1
fi
